{
  "rewrites": [
    {
      "source": "/ad",
      "destination": "/api/share"
    },
    {
      "source": "/share",
      "destination": "/api/share"
    },
    {
      "source": "/ad/:id",
      "destination": "/api/share?id=:id"
    },
    {
      "source": "/s/:id",
      "destination": "/api/share?id=:id"
    }
  ]
}
